{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Pulse Dash",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-std=c99",
                "-Wall",
                "-Wextra",
                "-Wpedantic",
                "-I",
                "${workspaceFolder}\\.H",
                "-I",
                "C:\\raylib\\w64devkit\\include",
                "${workspaceFolder}\\.C\\pulse_dash.c",
                "-o",
                "${workspaceFolder}\\.C\\output\\pulse_dash.exe",
                "-L",
                "C:\\raylib\\w64devkit\\lib",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm",
                "-lm"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "C:\\raylib\\w64devkit\\bin;${env:PATH}"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
